generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Association {
  id            String   @id @default(uuid())
  name          String
  siret         String   @unique
  email         String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
  documents     Document[]
  donations     Donation[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("MEMBER")
  associationId String?
  association   Association? @relation(fields: [associationId], references: [id])
  chatMessages  ChatMessage[]
  createdAt     DateTime @default(now())
}

model Document {
  id            String   @id @default(uuid())
  title         String
  type          String
  category      String   // "AG", "BILAN", "PROJET", "DECLARATION", "CONTRAT", "AUTRE"
  description   String?  // Description du document
  url           String
  fileName      String?  // Nom original du fichier
  fileSize      Int?     // Taille du fichier en octets
  mimeType      String?  // Type MIME du fichier
  associationId String
  association   Association @relation(fields: [associationId], references: [id])
  uploadedAt    DateTime @default(now())
  vectorized    Boolean  @default(false)
  
  // Mémoire associative
  isMemory      Boolean  @default(false)
  memoryDate    DateTime? // Date de l'événement (ex: date de l'AG)
  memoryType    String?  // "AG_ANNEE", "BILAN_EXERCICE", "PROJET_ANNEE"
  
  // Déclarations obligatoires
  isDeclaration Boolean  @default(false)
  declarationType String? // "PREFECTORALE", "FISCAL", "SOCIAL", "STATUTAIRE"
  declarationUrl String? // Lien vers service officiel
  declarationDeadline DateTime? // Date limite
  
  // Métadonnées
  tags          String[] // Tags pour recherche
  isPublic      Boolean  @default(false) // Visible sur page publique
  isArchived    Boolean  @default(false)
}

model ChatMessage {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  question      String
  answer        String
  createdAt     DateTime @default(now())
}

model Company {
  id            String   @id @default(uuid())
  name          String
  siret         String   @unique
  email         String   @unique
  address       String
  contactName   String
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  donations     Donation[]
  companyLabels CompanyLabel[]
}

model Donation {
  id            String   @id @default(uuid())
  amount        Float
  date          DateTime
  purpose       String   // "Emploi local", "Projet sportif", etc.
  status        String   @default("PENDING") // PENDING, CONFIRMED, RECEIVED
  
  // Relations
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  associationId String
  association   Association @relation(fields: [associationId], references: [id])
  
  // CERFA généré
  cerfaUrl      String?
  cerfaNumber   String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CerfaTemplate {
  id            String   @id @default(uuid())
  type          String   // "DON_EMPLOI_LOCAL", "SUBVENTION_CLUB"
  template      Json     // Structure du CERFA
  version       String   @default("2024")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model LabelTier {
  id          String   @id @default(uuid())
  name        String   // "Bronze", "Argent", "Or", "Diamant"
  minDonation Float    // 500, 2000, 5000, 10000
  minDuration Int?     // null, 1, 2, 3 ans
  benefits    Json     // Liste des bénéfices
  badgeUrl    String   // URL badge digital
  isActive    Boolean  @default(true)
  companyLabels CompanyLabel[]
}

model CompanyLabel {
  id          String   @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  labelTierId String
  labelTier   LabelTier @relation(fields: [labelTierId], references: [id])
  
  // Validations institutionnelles
  omsValidation    Boolean @default(false)
  omsValidationDate DateTime?
  cityValidation   Boolean @default(false)  
  cityValidationDate DateTime?
  intercoValidation Boolean @default(false)
  intercoValidationDate DateTime?
  
  // Documents
  certificateUrl    String?
  badgeUrl          String?
  
  startDate         DateTime @default(now())
  endDate           DateTime?
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LabelEvent {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  type        String   // "Ceremony", "Network", "Press"
  createdAt   DateTime @default(now())
}
